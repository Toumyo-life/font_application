<body class="custom-body" style="background-color: antiquewhite;">
  <div class="container py-3">

    <div class="container mb-4">
      <%= form_with url: root_path, method: :get, local: true, class: "d-flex gap-2 justify-content-center" do |f| %>
        <%= f.text_field :q, value: params[:q], placeholder: "タグや名前で検索", class: "form-control", style: "max-width: 400px;" %>
        <%= f.submit "検索", class: "btn btn-primary", style: "background-color: orange; border: none;" %>
        <% if params[:q].present? %>
          <%= link_to "クリア", root_path, class: "btn btn-outline-secondary" %>
        <% end %>
      <% end %>
    </div>

    <% if @font_designs.any? %>
      <div class="d-flex flex-wrap gap-4 justify-content-center">

        <% @font_designs.each do |font_design| %>
          <div class="card p-2" style="width: 320px;">

            <!-- 画像（中央寄せ） -->
            <div class="text-center">
              <%= link_to download_font_design_path(font_design) do %>

                <% if font_design.png_file.attached? %>
                  <%= image_tag font_design.png_file,
                      style: "height:200px; width:100%; object-fit:cover;" %>

                <% elsif font_design.svg_file.attached? %>
                  <div style="height:200px; width:100%; overflow:auto; border:1px #dcb89f solid;">
                    <%= raw font_design.svg_file.download.encode(
                      "UTF-8",
                      invalid: :replace,
                      undef: :replace,
                      replace: ""
                    ) %>
                  </div>

                <% else %>
                  <%= image_tag "default.png",
                      style: "height:200px; width:100%; object-fit:cover;" %>
                <% end %>
              <% end %>
            </div>

            <!-- 名前 + タグ（左寄せ） -->
            <div class="mt-2 text-start">

              <p class="mb-1">
                <%= font_design.user.last_name %>
                <%= font_design.user.first_name %>
              </p>

              <% font_design.tags.each do |tag| %>
                <span class="badge bg-secondary me-1">
                  <%= tag.name %>
                </span>
              <% end %>

            </div>

          </div>
        <% end %>

      </div>
    <% else %>
      <p>フォントデザインが登録されていません。</p>
    <% end %>

  </div>
</body>